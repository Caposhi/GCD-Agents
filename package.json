{
  "name": "gcd-social",
  "version": "0.1.0",
  "private": true,
  "description": "GCD-SOCIAL — autonomous multi-agent social posting system (harness skeleton).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
