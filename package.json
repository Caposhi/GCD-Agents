    "migrate": "node dist/state/migrate.js",
    "test:posting": "node dist/mcp/posting-tool/selftest.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.186",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "typescript": "^6.0.3"
  }
}
