# GCD-SOCIAL — environment template. Copy to .env for local dev.
# Real values are set in the Render dashboard (sync: false in render.yaml), NEVER committed.

# --- runtime ---
NODE_ENV=development
PORT=3000

# --- state ---
# Local Postgres for dev; Render injects DATABASE_URL in prod.
DATABASE_URL=postgres://localhost:5432/gcd_social

# --- model / credentials (credential-bound: owner provides) ---
ANTHROPIC_API_KEY=
IMAGEGEN_API_KEY=

# --- native publishing credentials (no aggregator) ---
# Instagram (Instagram-Login path → graph.instagram.com + IG user token)
IG_USER_ID=
IG_ACCESS_TOKEN=
# App ID/secret are for token exchange/refresh + appsecret_proof (not the post calls)
IG_APP_ID=
IG_APP_SECRET=
# Facebook Page (Facebook-Login path → graph.facebook.com + Page token)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
# Google Business Profile (OAuth)
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=

# --- HITL approval channel (locked decision: Slack primary, email fallback) ---
APPROVAL_CHANNEL_WEBHOOK=

# --- autonomy ---
# A = approval gate on every post (current). B = shadow/canary. C = full autonomy.
AUTONOMY_PHASE=A

# --- context compaction (ported from ECC strategic-compact) ---
# Context tokens before a compaction is signalled. 0 disables the context signal.
COMPACT_CONTEXT_THRESHOLD=160000
# Additional context tokens before the signal repeats.
COMPACT_CONTEXT_INTERVAL=60000

# --- session memory (ported from ECC memory-persistence) ---
# Upper bound on prior context (chars) reloaded at session start.
SESSION_START_MAX_CHARS=20000
